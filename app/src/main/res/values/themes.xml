<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.DecoPython" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryContainer">@color/app_primary_container</item>
        <item name="colorSecondary">@color/app_secondary</item>
        <item name="colorSecondaryContainer">@color/app_secondary_container</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorSurfaceContainerLow">@color/app_surface_low</item>
        <item name="colorSurfaceContainer">@color/app_surface_container</item>
        <item name="colorOutlineVariant">@color/app_outline_variant</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.DecoPython.MaterialAlertDialog</item>
    </style>

    <style name="Theme.DecoPython" parent="Base.Theme.DecoPython" />

    <style name="ThemeOverlay.DecoPython.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DecoPython.Dialog</item>
    </style>

    <style name="ShapeAppearance.DecoPython.Dialog" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">18dp</item>
    </style>
</resources>
